# Server
PORT=8080
NODE_ENV=development

# Gemini API
GEMINI_API_KEY="your_gemini_api_key"

# CORS
FRONTEND_URL="http://localhost:5173"

# Gemini retry (optional)
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_DELAY=1000

# MCP (Model Context Protocol) – optional agent loop with tools
# Set MCP_ENABLED=true and either MCP_SERVER_URL (HTTP) or MCP_COMMAND + MCP_ARGS (stdio)
# MCP_ENABLED=false
# MCP_SERVER_URL=http://localhost:3000/mcp
# MCP_COMMAND=npx
# MCP_ARGS=-y,@modelcontextprotocol/server-filesystem
# AGENT_MAX_ITERATIONS=10
