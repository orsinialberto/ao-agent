# Server
PORT=8080
NODE_ENV=development

# Ollama API (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# CORS
FRONTEND_URL="http://localhost:5173"

# Ollama retry (optional)
OLLAMA_RETRY_ATTEMPTS=3
OLLAMA_RETRY_DELAY=1000

# MCP (Model Context Protocol) – optional agent loop with tools
# Set MCP_ENABLED=true and either MCP_SERVER_URL (HTTP) or MCP_COMMAND + MCP_ARGS (stdio)
# MCP_ENABLED=false
# MCP_SERVER_URL=http://localhost:3000/mcp
# MCP_COMMAND=npx
# MCP_ARGS=-y,@modelcontextprotocol/server-filesystem
# AGENT_MAX_ITERATIONS=10
